  "components": {
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "password": { "type": "string", "minLength": 12 }
        }
      },
      "RegisterResponse": {
        "type": "object",
        "required": ["username", "userUid"],
        "properties": {
          "username": { "type": "string" },
          "userUid": { "type": "string", "format": "uuid" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": { "type": "string", "maxLength": 60 },
          "password": { "type": "string" }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": ["accessToken", "expiresAt", "userUid", "username"],
        "properties": {
          "accessToken": { "type": "string" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "userUid": { "type": "string", "format": "uuid" },
          "username": { "type": "string" }
        }
      },
      "UserProfileResponse": {
        "type": "object",
        "required": ["userUid", "username", "createdOn"],
        "properties": {
          "userUid": { "type": "string", "format": "uuid" },
          "username": { "type": "string" },
          "createdOn": { "type": "string", "format": "date-time" }
        }
      },
      "UsernameChangeResponse": {
        "type": "object",
        "required": ["newUsername"],
        "properties": {
          "newUsername": { "type": "string" }
        }
      },
      "PollStatus": {
        "type": "string",
        "enum": ["Draft", "Active", "Closed"]
      },
      "CreatePollRequest": {
        "type": "object",
        "required": ["title", "isPublic"],
        "properties": {
          "title": { "type": "string", "maxLength": 200 },
          "isPublic": { "type": "boolean" }
        }
      },
      "ChangePollStatusRequest": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": { "$ref": "#/components/schemas/PollStatus" }
        }
      },
      "AnswerOptionInput": {
        "type": "object",
        "required": ["text", "orderIndex"],
        "properties": {
          "text": { "type": "string", "maxLength": 200 },
          "orderIndex": { "type": "integer" }
        }
      },
      "AddPollQuestionRequest": {
        "type": "object",
        "required": ["text", "options", "pushImmediately"],
        "properties": {
          "text": { "type": "string", "maxLength": 500 },
          "options": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AnswerOptionInput" },
